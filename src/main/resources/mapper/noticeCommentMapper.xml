<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.brillar.mapper.NoticeCommentMapper">

    <!-- 댓글 등록 -->
    <insert id="insertCmt" parameterType="map">
        INSERT INTO noticeComment (
                                   userId,
                                   userName,
                                   comment,
                                   noticeSeq
        ) VALUES (
                    #{userId},
                    #{userName},
                    #{comment},
                    #{noticeSeq}
        )
    </insert>

</mapper>
