<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.brillar.mapper.LoginMapper">

  <select id="login" parameterType="String" resultType="kr.co.brillar.dto.UserDto">
SELECT 
    userRoleCode,
    userId,
    userName,
    userPassword
FROM user 
WHERE userId = #{userId}
  </select>
</mapper>