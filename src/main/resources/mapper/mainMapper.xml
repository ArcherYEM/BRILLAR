<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.brillar.mapper.MainMapper">

    <!-- 테스트용 -->
    <select id="getAllStatusNames" resultType="string">
        SELECT status_name
        FROM orderStatus
    </select>

    <select id="getNewProduct" resultType="kr.co.brillar.dto.MainDto">
            SELECT 
                product_id,
                product_name,
                product_desc,
                imageURL,
                price,
                created_at
            FROM product
            ORDER BY created_at DESC
            LIMIT 6;
    </select>

</mapper>
