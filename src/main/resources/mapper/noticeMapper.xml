<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.brillar.mapper.NoticeMapper">

<!--   공지사항 리스트 조회 + 페이징-->
    <select id="getPageList" resultType="kr.co.brillar.dto.NoticeDto">
        SELECT    noticeSeq
                , userId
                , title
                , contents
                , createdAt
                , updatedAt
        FROM      notice
        ORDER BY noticeSeq DESC
        LIMIT #{size} OFFSET #{offset}
    </select>

<!--    전체 게시글 수 조회-->
    <select id="getTotalCount" resultType="int">
        SELECT COUNT(*)
        FROM notice
    </select>

<!--    글 상세보기 조회-->
    <select id="getNoticeById" resultType="kr.co.brillar.dto.NoticeDto">
        SELECT noticeSeq
             , userId
             , title
             , contents
             , createdAt
             , updatedAt
        FROM notice
        WHERE noticeSeq = #{noticeSeq}
    </select>

</mapper>
