<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.brillar.mapper.JoinMapper">

    <!-- 중복확인 -->
    <select id="isDuplicate" parameterType="map" resultType="int">
        SELECT COUNT(*)
        FROM user
        <where>
            <if test="flag == 1">
                AND userId = #{data}
            </if>
            <if test="flag == 2">
                AND userEmail = #{data}
            </if>
            <if test="flag == 3">
                AND userPhone = #{data}
            </if>
        </where>
    </select>

    <insert id="register" parameterType="map">
        INSERT INTO user (
                          userRoleCode,
                          userId,
                          userPassword,
                          userEmail,
                          userName,
                          userBirth,
                          userGender,
                          userPhone,
                          userAddr1,
                          userAddr2
        ) VALUES (
                  #{userRoleCode},
                  #{userId},
                  #{userPassword},
                  #{userEmail},
                  #{userName},
                  #{userBirth},
                  #{userGender},
                  #{userPhone},
                  #{userAddr1},
                  #{userAddr2}
        )
    </insert>

</mapper>
